# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# For serverless functions (Netlify environment variables)
SUPABASE_URL=your-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Slack integration
NEXT_PUBLIC_SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
NEXT_PUBLIC_SLACK_CHANNEL_AIMY=your-slack-channel-id
NEXT_PUBLIC_SLACK_CHANNEL_BLOG=your-slack-channel-id

# Dashboard auth
NEXT_PUBLIC_DASHBOARD_PASSWORD=your-dashboard-password

# Agent webhook (local dev)
NEXT_PUBLIC_WEBHOOK_URL=http://localhost:3001/webhook/spawn-agent